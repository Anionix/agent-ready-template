# Required for local development.
# ローカル開発で必須。
DATABASE_URL="postgresql://app:app@localhost:5432/app"

# Required for local development.
# ローカル開発で必須。
REDIS_URL="redis://localhost:6379"

# Optional. Leave empty unless running external API integration tests.
# 任意。外部API統合テストを実行しない限り空でよい。
EXTERNAL_API_KEY=""

# Optional. Set to true for verbose local debugging.
# 任意。詳細ログを出す場合はtrueにする。
DEBUG_LOGS="false"
